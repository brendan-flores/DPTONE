# Supabase (required) — Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never commit; used for admin storage uploads if needed locally
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin subdomain only — required in production (set in Vercel; do not commit real value)
# NEXT_PUBLIC_ADMIN_HOST=admin.your-domain.com

# Optional: base URL for payment redirects (defaults to request origin)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# PayMongo (optional — only if using hosted online payment API)
# PAYMONGO_SECRET_KEY=
# PAYMONGO_WEBHOOK_SECRET=
